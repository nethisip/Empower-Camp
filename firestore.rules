rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Catch-all deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Reuseable helpers
    function isSignedIn() {
      return request.auth != null;
    }

    function isAdmin() {
      return isSignedIn() && 
             request.auth.token.email_verified == true && (
        exists(/databases/$(database)/documents/admins/$(request.auth.uid)) ||
        request.auth.token.email == "nethisip1313@gmail.com"
      );
    }

    function isValidId(id) {
      return id is string && id.size() <= 128 && id.matches('^[a-zA-Z0-9_\\-]+$');
    }

    function incoming() {
      return request.resource.data;
    }

    function existing() {
      return resource.data;
    }

    // Validation for Day entity
    function isValidDay(data) {
      return data.keys().hasAll(['id', 'label', 'date', 'theme', 'events']) &&
             data.keys().size() == 5 &&
             data.id is string && data.id.size() <= 100 &&
             data.label is string && data.label.size() <= 100 &&
             data.date is string && data.date.size() <= 100 &&
             data.theme is string && data.theme.size() <= 200 &&
             data.events is list && data.events.size() <= 100;
    }

    match /days/{dayId} {
      allow read: if true; // Public access to schedule
      
      allow create: if isAdmin() && isValidId(dayId) && isValidDay(incoming()) && incoming().id == dayId;
      
      allow update: if isAdmin() && isValidDay(incoming()) && incoming().id == existing().id;
      
      allow delete: if isAdmin();
    }

    match /test/connection {
      allow read: if true;
    }

    match /admins/{userId} {
      allow read: if isSignedIn() && request.auth.uid == userId;
      allow write: if false; // Managed via console
    }
  }
}
